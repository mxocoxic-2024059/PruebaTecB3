# Puerto propio del Servicio de Autenticacion
PORT=4001

# Entorno de ejecucion: development | production | test
NODE_ENV=development

# Cadena de conexion a MongoDB (independiente para este servicio)
MONGO_URI=mongodb://127.0.0.1:27017/service-auth

# Secreto utilizado para firmar los JWT (usar un valor largo y seguro en produccion)
JWT_SECRET=replace_with_shared_secret
JWT_EXPIRES_IN=1h

# Origen(es) permitidos para CORS, separados por coma
CORS_ORIGIN=http://localhost:5173
